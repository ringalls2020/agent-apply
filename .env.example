# Zero-config local default (works without PostgreSQL):
DATABASE_URL=sqlite+pysqlite:///./agent_apply.db
ENABLE_MAIN_SCHEMA_CREATE=true

# PostgreSQL example:
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/agent_apply

# Logging
LOG_LEVEL=INFO
SQLALCHEMY_LOG_QUERIES=false

# Main backend -> cloud automation service
CLOUD_AUTOMATION_BASE_URL=http://127.0.0.1:8100
CLOUD_AUTOMATION_SERVICE_ID=main-api
CLOUD_AUTOMATION_AUDIENCE=job-intel-api
CLOUD_AUTOMATION_SIGNING_SECRET=dev-cloud-signing-secret
CLOUD_AUTOMATION_TIMEOUT_SECONDS=20

# Cloud callback verification on main backend
CLOUD_CALLBACK_SIGNING_SECRET=dev-cloud-signing-secret
CLOUD_CALLBACK_SIGNATURE_SECRET=dev-cloud-signing-secret
CLOUD_CALLBACK_AUDIENCE=main-api
CLOUD_CALLBACK_ISSUER=job-intel-api
CLOUD_CALLBACK_MAX_CLOCK_SKEW_SECONDS=300

# Default per-user autonomous apply cap on main backend
DEFAULT_APPLY_DAILY_CAP=25
ENABLE_DEV_RUN_AGENT=true
ENABLE_RUN_AGENT_DISCOVERY_KICK=true
# Shared 21-day listing freshness window across backend + cloud automation
JOB_LISTING_TTL_DAYS=21

# User auth (main backend)
USER_AUTH_SIGNING_SECRET=dev-user-auth-secret
USER_AUTH_ISSUER=main-api
USER_AUTH_AUDIENCE=agent-apply-frontend
USER_AUTH_TOKEN_TTL_SECONDS=604800
# Required in non-development environments for encrypted profile fields.
USER_PROFILE_ENCRYPTION_KEY=
# Admin dashboard controls (defaults enabled only in local/dev/test).
ENABLE_ADMIN_DASHBOARD=true
ADMIN_DASHBOARD_SECRET=

# Cloud automation database and scheduler
JOBS_DATABASE_URL=sqlite+pysqlite:///./jobs_intel.db
DISCOVERY_INTERVAL_SECONDS=21600
DISCOVERY_WORKER_LOOP_SLEEP_SECONDS=15
COMMON_CRAWL_INTERVAL_SECONDS=86400
ENABLE_EMBEDDED_DISCOVERY_LOOP=false
MATCH_WORKER_POLL_SECONDS=5
APPLY_WORKER_POLL_SECONDS=5
MATCH_WORKER_CONCURRENCY=1
APPLY_WORKER_CONCURRENCY=1
# Shared cloud HTTP client timeout for adapters/callbacks/OpenAI
CLOUD_HTTP_TIMEOUT_SECONDS=20
# Callback delivery retry controls (cloud -> main)
CALLBACK_RETRY_MAX_ATTEMPTS=3
CALLBACK_RETRY_BASE_DELAY_MS=250
ENABLE_CLOUD_SCHEMA_CREATE=true
# Token-first discovery inputs and crawler behavior.
SEED_MANIFEST_URLS=http://127.0.0.1:8100/internal/seed-manifests/companies.json
SEED_SOURCE_PAGE_URLS=https://remoteintech.company/companies/,https://remoteintech.company/browse/worldwide/,https://remoteintech.company/browse/americas/,https://remoteintech.company/browse/europe/,https://remoteintech.company/browse/fully-remote/,https://remoteintech.company/browse/remote-first/,https://remoteintech.company/browse/remote-friendly/,https://remoteintech.company/browse/hybrid/,https://remoteintech.company/browse/python/,https://remoteintech.company/browse/javascript/
SEED_MANIFEST_BUILD_INTERVAL_SECONDS=86400
SEED_MANIFEST_MAX_RETRIES=3
SEED_MANIFEST_TIMEOUT_SECONDS=20
SEED_MANIFEST_REQUIRE_SERVICE_JWT=true
SEED_MANIFEST_ALLOWED_ISSUERS=main-api,job-intel-api
SEED_MANIFEST_SERVICE_ISSUER=job-intel-api
SEED_MANIFEST_SERVICE_AUDIENCE=job-intel-api
SEED_MANIFEST_SERVICE_SIGNING_SECRET=dev-cloud-signing-secret
DISCOVERY_USER_AGENT=agent-apply-discovery-bot/1.0
DISCOVERY_CONTACT_EMAIL=
DISCOVERY_DEFAULT_CRAWL_DELAY_SECONDS=2
DISCOVERY_MAX_RETRIES=3
DISCOVERY_TIMEOUT_SECONDS=20
TOKEN_VALIDATION_RECHECK_HOURS=24
COMMON_CRAWL_LOOKBACK_INDEXES=2
COMMON_CRAWL_MAX_PAGES_PER_PATTERN=3
COMMON_CRAWL_MAX_RECORDS_PER_PATTERN=1500

# Cloud callback target URL (optional; callback emitter disabled when unset)
MAIN_CALLBACK_URL=http://127.0.0.1:8000/internal/cloud/callbacks/apply-result

# Cloud autonomous apply controls
ENABLE_AUTONOMOUS_BROWSING=false
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_NAV_TIMEOUT_SECONDS=20
PLAYWRIGHT_ACTION_TIMEOUT_SECONDS=5
PLAYWRIGHT_CAPTURE_SCREENSHOTS=true
# Dev-only manual review mode (requires ENABLE_AUTONOMOUS_BROWSING=true)
ENABLE_APPLY_DEV_REVIEW_MODE=false
APPLY_DEV_REVIEW_SUBMIT_TIMEOUT_SECONDS=300
APPLY_DEV_REVIEW_POLL_INTERVAL_MS=500
APPLY_DEV_REVIEW_SLOW_MO_MS=120
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=20

# Frontend GraphQL BFF -> backend API
BACKEND_API_BASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_ENABLE_RUN_AGENT_DEV=true
