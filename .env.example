# Zero-config local default (works without PostgreSQL):
DATABASE_URL=sqlite+pysqlite:///./agent_apply.db

# PostgreSQL example:
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/agent_apply

# Main backend -> cloud automation service
CLOUD_AUTOMATION_BASE_URL=http://127.0.0.1:8100
CLOUD_AUTOMATION_SERVICE_ID=main-api
CLOUD_AUTOMATION_AUDIENCE=job-intel-api
CLOUD_AUTOMATION_SIGNING_SECRET=dev-cloud-signing-secret
CLOUD_AUTOMATION_TIMEOUT_SECONDS=20

# Cloud callback verification on main backend
CLOUD_CALLBACK_SIGNING_SECRET=dev-cloud-signing-secret
CLOUD_CALLBACK_SIGNATURE_SECRET=dev-cloud-signing-secret
CLOUD_CALLBACK_AUDIENCE=main-api
CLOUD_CALLBACK_ISSUER=job-intel-api
CLOUD_CALLBACK_MAX_CLOCK_SKEW_SECONDS=300

# Default per-user autonomous apply cap on main backend
DEFAULT_APPLY_DAILY_CAP=25

# User auth (main backend)
USER_AUTH_SIGNING_SECRET=dev-user-auth-secret
USER_AUTH_ISSUER=main-api
USER_AUTH_AUDIENCE=agent-apply-frontend
USER_AUTH_TOKEN_TTL_SECONDS=604800

# Cloud automation database and scheduler
JOBS_DATABASE_URL=sqlite+pysqlite:///./jobs_intel.db
DISCOVERY_INTERVAL_SECONDS=21600
ENABLE_EMBEDDED_DISCOVERY_LOOP=true
# Set true to disable synthetic fallback adapters and use only live providers.
USE_ONLY_LIVE_ADAPTERS=true
# Comma-separated live provider seeds.
GREENHOUSE_BOARD_TOKENS=
LEVER_COMPANIES=
SMARTRECRUITERS_COMPANIES=

# Cloud callback target URL (optional; callback emitter disabled when unset)
MAIN_CALLBACK_URL=http://127.0.0.1:8000/internal/cloud/callbacks/apply-result

# Frontend GraphQL BFF -> backend API
BACKEND_API_BASE_URL=http://127.0.0.1:8000
